{
    "id": "com.mattermost.plugin-task",
    "name": "Task",
    "version": "0.5.7",
    "description": "Quản lý công việc (task) trong Mattermost: tạo task, gán người làm, nhắc hạn và theo dõi tiến độ.",
    "homepage_url": "https://github.com/naicoi92/mattermost-plugin-task",
    "support_url": "https://github.com/naicoi92/mattermost-plugin-task/issues",
    "icon_path": "assets/starter-template-icon.svg",
    "min_server_version": "11.8.0",
    "server": {
        "executables": {
            "linux-amd64": "server/dist/plugin-linux-amd64",
            "linux-arm64": "server/dist/plugin-linux-arm64",
            "darwin-amd64": "server/dist/plugin-darwin-amd64",
            "darwin-arm64": "server/dist/plugin-darwin-arm64",
            "windows-amd64": "server/dist/plugin-windows-amd64.exe"
        }
    },
    "webapp": {
        "bundle_path": "webapp/dist/main.js"
    },
    "settings_schema": {
        "header": "",
        "footer": "",
        "settings": [
            {
                "key": "reminderdefaultoffsetminutes",
                "display_name": "Default Reminder Offset (minutes)",
                "type": "number",
                "help_text": "Default number of minutes before the due date to send a task reminder.",
                "default": 15
            },
            {
                "key": "enabledmnotifications",
                "display_name": "Enable DM Notifications",
                "type": "bool",
                "help_text": "When enabled, the bot sends direct message notifications for task assignments, completions, comments, and reminders.",
                "default": true
            }
        ]
    }
}
